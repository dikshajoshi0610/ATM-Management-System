<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <!-- Login Servlet -->
    <servlet>
     <servlet-name>LoginServlet</servlet-name>
     <servlet-class>com.atm.LoginServlet</servlet-class>
 </servlet>

    <servlet-mapping>
     <servlet-name>LoginServlet</servlet-name>
     <url-pattern>/login</url-pattern>
    </servlet-mapping>


    <!-- Balance Servlet -->
    <servlet>
        <servlet-name>BalanceServlet</servlet-name>
        <servlet-class>com.atm.BalanceServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BalanceServlet</servlet-name>
        <url-pattern>/balance</url-pattern>
    </servlet-mapping>


    <!-- Deposit Servlet -->
    <servlet>
        <servlet-name>DepositServlet</servlet-name>
        <servlet-class>com.atm.DepositServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DepositServlet</servlet-name>
        <url-pattern>/deposit</url-pattern>
    </servlet-mapping>


    <!-- Withdraw Servlet -->
    <servlet>
        <servlet-name>WithdrawServlet</servlet-name>
        <servlet-class>com.atm.WithdrawServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>WithdrawServlet</servlet-name>
        <url-pattern>/withdraw</url-pattern>
    </servlet-mapping>

    <!-- Change PIN Servlet -->
    <servlet>
        <servlet-name>ChangePinServlet</servlet-name>
        <servlet-class>com.atm.ChangePinServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ChangePinServlet</servlet-name>
        <url-pattern>/changePin</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.atm.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Mini Statement Servlet -->
    <servlet>
        <servlet-name>MiniStatementServlet</servlet-name>
        <servlet-class>com.atm.MiniStatementServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MiniStatementServlet</servlet-name>
        <url-pattern>/miniStatement</url-pattern>
    </servlet-mapping>

</web-app>